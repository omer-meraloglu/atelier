# Supabase — from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site origin, e.g. https://your-app.vercel.app — used for auth
# email redirects. Optional locally (falls back to request headers), set it
# in production.
NEXT_PUBLIC_SITE_URL=

# Server only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=
FAL_KEY=

# Optional: adds "Mock (dev only)" try-on and video models AND the mock
# billing provider, so generation + subscribe/spend/refund loops run fully
# offline. Leave unset in prod.
ENABLE_MOCK_PROVIDER=

# ————— Billing —————
# Which adapter serves checkout/webhooks: "paddle" or "mock".
# Defaults: mock when ENABLE_MOCK_PROVIDER=1, otherwise paddle.
BILLING_PROVIDER=

# Paddle (https://developer.paddle.com) — sandbox by default; set
# PADDLE_ENV=live for production. All server-only.
PADDLE_ENV=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Catalog price ids (create products/prices in the Paddle dashboard):
PADDLE_PRICE_STARTER=
PADDLE_PRICE_STUDIO=
PADDLE_PRICE_PACK_100=
PADDLE_PRICE_PACK_500=
