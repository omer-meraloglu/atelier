# Supabase — from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=
FAL_KEY=

# Optional: adds "Mock (dev only)" try-on and video models so the full
# generate lifecycle can be exercised without a FAL_KEY. Leave unset in prod.
ENABLE_MOCK_PROVIDER=
